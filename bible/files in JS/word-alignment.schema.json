{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bible-db.example/schemas/word-alignment.json",
  "title": "WordAlignment",
  "description": "Slot-by-slot word mapping across editions for one verse — powers parallel Bible diff UI",
  "type": "object",
  "required": ["_id", "canonicalRef", "alignments"],
  "additionalProperties": false,
  "properties": {
    "_id":          { "type": "string" },
    "canonicalRef": { "type": "string", "pattern": "^[A-Z0-9]+\\.[0-9]+\\.[0-9]+$" },
    "alignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slot", "words"],
        "additionalProperties": false,
        "properties": {
          "slot": { "type": "integer", "minimum": 1 },
          "words": {
            "type": "object",
            "description": "Map of editionId → array of words for this slot",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "strongsRef": {
            "type": "string",
            "pattern": "^[HG][0-9]{4}$",
            "description": "Strong's number from source-language edition for this slot"
          }
        }
      }
    }
  }
}
