      "chapters": [
        {
          "chapter": 77,
          "entries": [
            {
              "rowId": 1,
              "keyParts": [
                "label"
              ],
              "value": "77"
            },
            {
              "rowId": 2,
              "keyParts": [
                "d",
                "content"
              ],
              "value": "Para Jedutum, regente do coral: salmo de Asafe."
            },
            {
              "rowId": 3,
              "keyParts": [
                3,
                "q",
                "verse",
                "v1",
                "label"
              ],
              "value": "1"
            },
            {
              "rowId": 4,
              "keyParts": [
                4,
                "q",
                "verse",
                "v1",
                "content"
              ],
              "value": "Clamo a Deus; sim, grito bem alto."
            },
            {
              "rowId": 5,
              "keyParts": [
                5,
                "q",
                "verse",
                "v1",
                "content"
              ],
              "value": "Quem dera Deus me ouvisse!"
            },
            {
              "rowId": 6,
              "keyParts": [
                6,
                "q",
                "verse",
                "v1",
                "plain_text"
              ],
              "value": "1 Clamo a Deus; sim, grito bem alto. Quem dera Deus me ouvisse!"
            },
            {
              "rowId": 7,
              "keyParts": [
                7,
                "q",
                "verse",
                "v2",
                "label"
              ],
              "value": "2"
            },
            {
              "rowId": 8,
              "keyParts": [
                8,
                "q",
                "verse",
                "v2",
                "content"
              ],
              "value": "Quando eu estava angustiado,"
            },
            {
              "rowId": 9,
              "keyParts": [
                9,
                "q",
                "verse",
                "v2",
                "content"
              ],
              "value": "busquei o Senhor."
            },
            {
              "rowId": 10,
              "keyParts": [
                10,
                "q",
                "verse",
                "v2",
                "content"
              ],
              "value": "Orei a noite toda, de mãos estendidas para o céu,"
            },
            {
              "rowId": 11,
              "keyParts": [
                11,
                "q",
                "verse",
                "v2",
                "content"
              ],
              "value": "mas minha alma recusou ser consolada."
            },
            {
              "rowId": 12,
              "keyParts": [
                12,
                "q",
                "verse",
                "v2",
                "plain_text"
              ],
              "value": "2 Quando eu estava angustiado, busquei o Senhor. Orei a noite toda, de mãos estendidas para o céu, mas minha alma recusou ser consolada."
            },
            {
              "rowId": 13,
              "keyParts": [
                13,
                "q",
                "verse",
                "v3",
                "label"
              ],
              "value": "3"
            },
            {
              "rowId": 14,
              "keyParts": [
                14,
                "q",
                "verse",
                "v3",
                "content"
              ],
              "value": "Lembro-me de Deus e começo a gemer;"
            },
            {
              "rowId": 15,
              "keyParts": [
                15,
                "q",
                "verse",
                "v3",
                "content"
              ],
              "value": "desfaleço, ansioso por sua ajuda."
            },
            {
              "rowId": 16,
              "keyParts": [
                16,
                "q",
                "verse",
                "v3",
                "plain_text"
              ],
              "value": "3 Lembro-me de Deus e começo a gemer; desfaleço, ansioso por sua ajuda."
            },
            {
              "rowId": 17,
              "keyParts": [
                "qa",
                "heading"
              ],
              "value": "Interlúdio"
            },
            {
              "rowId": 18,
              "keyParts": [
                18,
                "q",
                "verse",
                "v4",
                "label"
              ],
              "value": "4"
            },
            {
              "rowId": 19,
              "keyParts": [
                19,
                "q",
                "verse",
                "v4",
                "content"
              ],
              "value": "Tu não me deixas dormir;"
            },
            {
              "rowId": 20,
              "keyParts": [
                20,
                "q",
                "verse",
                "v4",
                "content"
              ],
              "value": "estou tão desesperado que nem consigo falar!"
            },
            {
              "rowId": 21,
              "keyParts": [
                21,
                "q",
                "verse",
                "v4",
                "plain_text"
              ],
              "value": "4 Tu não me deixas dormir; estou tão desesperado que nem consigo falar!"
            },
            {
              "rowId": 22,
              "keyParts": [
                22,
                "q",
                "verse",
                "v5",
                "label"
              ],
              "value": "5"
            },
            {
              "rowId": 23,
              "keyParts": [
                23,
                "q",
                "verse",
                "v5",
                "content"
              ],
              "value": "Penso nos dias que passaram,"
            },
            {
              "rowId": 24,
              "keyParts": [
                24,
                "q",
                "verse",
                "v5",
                "content"
              ],
              "value": "nos anos que há muito se foram."
            },
            {
              "rowId": 25,
              "keyParts": [
                25,
                "q",
                "verse",
                "v5",
                "plain_text"
              ],
              "value": "5 Penso nos dias que passaram, nos anos que há muito se foram."
            },
            {
              "rowId": 26,
              "keyParts": [
                26,
                "q",
                "verse",
                "v6",
                "label"
              ],
              "value": "6"
            },
            {
              "rowId": 27,
              "keyParts": [
                27,
                "q",
                "verse",
                "v6",
                "content"
              ],
              "value": "À noite, relembro canções alegres;"
            },
            {
              "rowId": 28,
              "keyParts": [
                28,
                "q",
                "verse",
                "v6",
                "content"
              ],
              "value": "consulto minha alma e procuro compreender minha situação."
            },
            {
              "rowId": 29,
              "keyParts": [
                29,
                "q",
                "verse",
                "v6",
                "plain_text"
              ],
              "value": "6 À noite, relembro canções alegres; consulto minha alma e procuro compreender minha situação."
            },
            {
              "rowId": 30,
              "keyParts": [
                30,
                "q",
                "verse",
                "v7",
                "label"
              ],
              "value": "7"
            },
            {
              "rowId": 31,
              "keyParts": [
                31,
                "q",
                "verse",
                "v7",
                "content"
              ],
              "value": "Acaso o Senhor me rejeitou em definitivo?"
            },
            {
              "rowId": 32,
              "keyParts": [
                32,
                "q",
                "verse",
                "v7",
                "content"
              ],
              "value": "Jamais voltará a ser bondoso comigo?"
            },
            {
              "rowId": 33,
              "keyParts": [
                33,
                "q",
                "verse",
                "v7",
                "plain_text"
              ],
              "value": "7 Acaso o Senhor me rejeitou em definitivo? Jamais voltará a ser bondoso comigo?"
            },
            {
              "rowId": 34,
              "keyParts": [
                34,
                "q",
                "verse",
                "v8",
                "label"
              ],
              "value": "8"
            },
            {
              "rowId": 35,
              "keyParts": [
                35,
                "q",
                "verse",
                "v8",
                "content"
              ],
              "value": "Seu amor se foi para nunca mais voltar?"
            },
            {
              "rowId": 36,
              "keyParts": [
                36,
                "q",
                "verse",
                "v8",
                "content"
              ],
              "value": "Deixou de cumprir suas promessas para sempre?"
            },
            {
              "rowId": 37,
              "keyParts": [
                37,
                "q",
                "verse",
                "v8",
                "plain_text"
              ],
              "value": "8 Seu amor se foi para nunca mais voltar? Deixou de cumprir suas promessas para sempre?"
            },
            {
              "rowId": 38,
              "keyParts": [
                38,
                "q",
                "verse",
                "v9",
                "label"
              ],
              "value": "9"
            },
            {
              "rowId": 39,
              "keyParts": [
                39,
                "q",
                "verse",
                "v9",
                "content"
              ],
              "value": "Deus se esqueceu de ser bondoso?"
            },
            {
              "rowId": 40,
              "keyParts": [
                40,
                "q",
                "verse",
                "v9",
                "content"
              ],
              "value": "Em sua ira, fechou a porta para a compaixão?"
            },
            {
              "rowId": 41,
              "keyParts": [
                41,
                "q",
                "verse",
                "v9",
                "plain_text"
              ],
              "value": "9 Deus se esqueceu de ser bondoso? Em sua ira, fechou a porta para a compaixão?"
            },
            {
              "rowId": 42,
              "keyParts": [
                "qa",
                "heading"
              ],
              "value": "Interlúdio"
            },
            {
              "rowId": 43,
              "keyParts": [
                43,
                "q",
                "verse",
                "v10",
                "label"
              ],
              "value": "10"
            },
            {
              "rowId": 44,
              "keyParts": [
                44,
                "q",
                "verse",
                "v10",
                "content"
              ],
              "value": "Pensei: “É por esta razão que sofro;"
            },
            {
              "rowId": 45,
              "keyParts": [
                45,
                "q",
                "verse",
                "v10",
                "content"
              ],
              "value": "o Altíssimo voltou sua mão direita contra mim”."
            },
            {
              "rowId": 46,
              "keyParts": [
                46,
                "q",
                "verse",
                "v10",
                "plain_text"
              ],
              "value": "10 Pensei: “É por esta razão que sofro; o Altíssimo voltou sua mão direita contra mim”."
            },
            {
              "rowId": 47,
              "keyParts": [
                47,
                "q",
                "verse",
                "v11",
                "label"
              ],
              "value": "11"
            },
            {
              "rowId": 48,
              "keyParts": [
                48,
                "q",
                "verse",
                "v11",
                "content"
              ],
              "value": "Depois, porém, lembro-me de tudo que fizeste, S"
            },
            {
              "rowId": 49,
              "keyParts": [
                49,
                "q",
                "verse",
                "v11",
                "sc"
              ],
              "value": "enhor"
            },
            {
              "rowId": 50,
              "keyParts": [
                50,
                "q",
                "verse",
                "v11",
                "content"
              ],
              "value": ";"
            },
            {
              "rowId": 51,
              "keyParts": [
                51,
                "q",
                "verse",
                "v11",
                "content"
              ],
              "value": "recordo-me de tuas maravilhas do passado."
            },
            {
              "rowId": 52,
              "keyParts": [
                52,
                "q",
                "verse",
                "v11",
                "plain_text"
              ],
              "value": "11 Depois, porém, lembro-me de tudo que fizeste, S enhor ; recordo-me de tuas maravilhas do passado."
            },
            {
              "rowId": 53,
              "keyParts": [
                53,
                "q",
                "verse",
                "v12",
                "label"
              ],
              "value": "12"
            },
            {
              "rowId": 54,
              "keyParts": [
                54,
                "q",
                "verse",
                "v12",
                "content"
              ],
              "value": "Estão sempre em meus pensamentos;"
            },
            {
              "rowId": 55,
              "keyParts": [
                55,
                "q",
                "verse",
                "v12",
                "content"
              ],
              "value": "não deixo de refletir sobre teus poderosos feitos."
            },
            {
              "rowId": 56,
              "keyParts": [
                56,
                "q",
                "verse",
                "v12",
                "plain_text"
              ],
              "value": "12 Estão sempre em meus pensamentos; não deixo de refletir sobre teus poderosos feitos."
            },
            {
              "rowId": 57,
              "keyParts": [
                57,
                "q",
                "verse",
                "v13",
                "label"
              ],
              "value": "13"
            },
            {
              "rowId": 58,
              "keyParts": [
                58,
                "q",
                "verse",
                "v13",
                "content"
              ],
              "value": "Teus caminhos, ó Deus, são santos;"
            },
            {
              "rowId": 59,
              "keyParts": [
                59,
                "q",
                "verse",
                "v13",
                "content"
              ],
              "value": "que deus é poderoso como o nosso Deus?"
            },
            {
              "rowId": 60,
              "keyParts": [
                60,
                "q",
                "verse",
                "v13",
                "plain_text"
              ],
              "value": "13 Teus caminhos, ó Deus, são santos; que deus é poderoso como o nosso Deus?"
            },
            {
              "rowId": 61,
              "keyParts": [
                61,
                "q",
                "verse",
                "v14",
                "label"
              ],
              "value": "14"
            },
            {
              "rowId": 62,
              "keyParts": [
                62,
                "q",
                "verse",
                "v14",
                "content"
              ],
              "value": "És o Deus que realiza maravilhas;"
            },
            {
              "rowId": 63,
              "keyParts": [
                63,
                "q",
                "verse",
                "v14",
                "content"
              ],
              "value": "mostras o teu poder entre as nações!"
            },
            {
              "rowId": 64,
              "keyParts": [
                64,
                "q",
                "verse",
                "v14",
                "plain_text"
              ],
              "value": "14 És o Deus que realiza maravilhas; mostras o teu poder entre as nações!"
            },
            {
              "rowId": 65,
              "keyParts": [
                65,
                "q",
                "verse",
                "v15",
                "label"
              ],
              "value": "15"
            },
            {
              "rowId": 66,
              "keyParts": [
                66,
                "q",
                "verse",
                "v15",
                "content"
              ],
              "value": "Com teu braço forte resgataste teu povo,"
            },
            {
              "rowId": 67,
              "keyParts": [
                67,
                "q",
                "verse",
                "v15",
                "content"
              ],
              "value": "os descendentes de Jacó e José."
            },
            {
              "rowId": 68,
              "keyParts": [
                68,
                "q",
                "verse",
                "v15",
                "plain_text"
              ],
              "value": "15 Com teu braço forte resgataste teu povo, os descendentes de Jacó e José."
            },
            {
              "rowId": 69,
              "keyParts": [
                "qa",
                "heading"
              ],
              "value": "Interlúdio"
            },
            {
              "rowId": 70,
              "keyParts": [
                70,
                "q",
                "verse",
                "v16",
                "label"
              ],
              "value": "16"
            },
            {
              "rowId": 71,
              "keyParts": [
                71,
                "q",
                "verse",
                "v16",
                "content"
              ],
              "value": "As águas te viram, ó Deus,"
            },
            {
              "rowId": 72,
              "keyParts": [
                72,
                "q",
                "verse",
                "v16",
                "content"
              ],
              "value": "as águas te viram e estremeceram;"
            },
            {
              "rowId": 73,
              "keyParts": [
                73,
                "q",
                "verse",
                "v16",
                "content"
              ],
              "value": "até as profundezas do mar se agitaram."
            },
            {
              "rowId": 74,
              "keyParts": [
                74,
                "q",
                "verse",
                "v16",
                "plain_text"
              ],
              "value": "16 As águas te viram, ó Deus, as águas te viram e estremeceram; até as profundezas do mar se agitaram."
            },
            {
              "rowId": 75,
              "keyParts": [
                75,
                "q",
                "verse",
                "v17",
                "label"
              ],
              "value": "17"
            },
            {
              "rowId": 76,
              "keyParts": [
                76,
                "q",
                "verse",
                "v17",
                "content"
              ],
              "value": "As nuvens derramaram chuva,"
            },
            {
              "rowId": 77,
              "keyParts": [
                77,
                "q",
                "verse",
                "v17",
                "content"
              ],
              "value": "os trovões ressoaram nas alturas,"
            },
            {
              "rowId": 78,
              "keyParts": [
                78,
                "q",
                "verse",
                "v17",
                "content"
              ],
              "value": "os teus relâmpagos riscaram os céus."
            },
            {
              "rowId": 79,
              "keyParts": [
                79,
                "q",
                "verse",
                "v17",
                "plain_text"
              ],
              "value": "17 As nuvens derramaram chuva, os trovões ressoaram nas alturas, os teus relâmpagos riscaram os céus."
            },
            {
              "rowId": 80,
              "keyParts": [
                80,
                "q",
                "verse",
                "v18",
                "label"
              ],
              "value": "18"
            },
            {
              "rowId": 81,
              "keyParts": [
                81,
                "q",
                "verse",
                "v18",
                "content"
              ],
              "value": "No redemoinho ouviu-se o estrondo de teu trovão;"
            },
            {
              "rowId": 82,
              "keyParts": [
                82,
                "q",
                "verse",
                "v18",
                "content"
              ],
              "value": "os relâmpagos iluminaram o mundo,"
            },
            {
              "rowId": 83,
              "keyParts": [
                83,
                "q",
                "verse",
                "v18",
                "content"
              ],
              "value": "e a terra tremeu e se abalou."
            },
            {
              "rowId": 84,
              "keyParts": [
                84,
                "q",
                "verse",
                "v18",
                "plain_text"
              ],
              "value": "18 No redemoinho ouviu-se o estrondo de teu trovão; os relâmpagos iluminaram o mundo, e a terra tremeu e se abalou."
            },
            {
              "rowId": 85,
              "keyParts": [
                85,
                "q",
                "verse",
                "v19",
                "label"
              ],
              "value": "19"
            },
            {
              "rowId": 86,
              "keyParts": [
                86,
                "q",
                "verse",
                "v19",
                "content"
              ],
              "value": "Teu caminho passou pelo mar,"
            },
            {
              "rowId": 87,
              "keyParts": [
                87,
                "q",
                "verse",
                "v19",
                "content"
              ],
              "value": "teu trajeto, pelas águas poderosas,"
            },
            {
              "rowId": 88,
              "keyParts": [
                88,
                "q",
                "verse",
                "v19",
                "content"
              ],
              "value": "e ninguém percebeu teus passos."
            },
            {
              "rowId": 89,
              "keyParts": [
                89,
                "q",
                "verse",
                "v19",
                "plain_text"
              ],
              "value": "19 Teu caminho passou pelo mar, teu trajeto, pelas águas poderosas, e ninguém percebeu teus passos."
            },
            {
              "rowId": 90,
              "keyParts": [
                90,
                "q",
                "verse",
                "v20",
                "label"
              ],
              "value": "20"
            },
            {
              "rowId": 91,
              "keyParts": [
                91,
                "q",
                "verse",
                "v20",
                "content"
              ],
              "value": "Conduziste teu povo como um rebanho de ovelhas,"
            },
            {
              "rowId": 92,
              "keyParts": [
                92,
                "q",
                "verse",
                "v20",
                "content"
              ],
              "value": "pelas mãos de Moisés e Arão."
            },
            {
              "rowId": 93,
              "keyParts": [
                93,
                "q",
                "verse",
                "v20",
                "plain_text"
              ],
              "value": "20 Conduziste teu povo como um rebanho de ovelhas, pelas mãos de Moisés e Arão."
            }
          ]
        }
      ]
    }
  ]
}