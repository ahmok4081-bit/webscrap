              "keyParts": [
                50,
                "p2",
                "verse",
                "v9",
                "content"
              ],
              "value": "These were the cities designated for all the people of Israel and"
            },
            {
              "rowId": 51,
              "keyParts": [
                51,
                "p2",
                "verse",
                "v9",
                "note",
                "x"
              ],
              "value": "#Num. 35:15"
            },
