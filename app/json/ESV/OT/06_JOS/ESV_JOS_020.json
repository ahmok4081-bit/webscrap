              "rowId": 25,
              "keyParts": [
                25,
                "p1",
                "verse",
                "v6",
                "content"
              ],
              "value": "And he shall remain in that city"
            },
            {
              "rowId": 26,
              "keyParts": [
                26,
                "p1",
                "verse",
                "v6",
                "note",
                "x"
              ],
              "value": "#Num. 35:12,24,25"
