              "keyParts": [
                40,
                "p3",
                "verse",
                "v8",
                "content"
              ],
              "value": "From"
            },
            {
              "rowId": 41,
              "keyParts": [
                41,
                "p3",
                "verse",
                "v8",
                "note",
                "x"
