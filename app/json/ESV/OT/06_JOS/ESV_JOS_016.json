              "keyParts": [
                13,
                "p1",
                "verse",
                "v3",
                "label"
              ],
              "value": "3"
            },
            {
              "rowId": 14,
              "keyParts": [
                14,
                "p1",
                "verse",
                "v3",
                "content"
              ],
