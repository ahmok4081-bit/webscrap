              "rowId": 30,
              "keyParts": [
                30,
                "p3",
                "verse",
                "v6",
                "content"
              ],
              "value": "and the boundary goes from there to the sea. On the north is"
            },
            {
              "rowId": 31,
              "keyParts": [
                31,
                "p3",
                "verse",
                "v6",
                "note",
                "x"
              ],
              "value": "#ch.17:7"
