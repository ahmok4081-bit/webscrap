                "p1",
                "verse",
                "v1",
                "label"
              ],
              "value": "1"
            },
            {
              "rowId": 4,
              "keyParts": [
                4,
                "p1",
                "verse",
                "v1",
                "content"
              ],
              "value": "The allotment of the people of Joseph went from the Jordan by Jericho, east of the waters of Jericho,"
            },
            {
              "rowId": 5,
              "keyParts": [
                5,
                "p1",
                "verse",
                "v1",
                "note",
                "x"
