              "keyParts": [
                "v004_ESV_JOS_016",
                23,
                "p2",
                "verse",
                "v4",
                "plain_text"
              ],
              "value": "4 The people of Joseph, Manasseh and Ephraim, received their inheritance."
            },
            {
              "rowId": 24,
              "keyParts": [
                24,
                "p3",
                "verse",
                "v5",
