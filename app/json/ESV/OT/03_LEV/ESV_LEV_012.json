                "p1",
                "verse",
                "v4",
                "content"
              ],
              "value": "Then she shall continue for thirty-three days in the blood of her purifying. She shall not touch anything holy, nor come into the sanctuary, until the days of her purifying are completed."
            },
            {
              "rowId": 22,
              "keyParts": [
                "v004_ESV_LEV_012",
                22,
                "p1",
                "verse",
                "v4",
                "plain_text"
              ],
              "value": "4 Then she shall continue for thirty-three days in the blood of her purifying. She shall not touch anything holy, nor come into the sanctuary, until the days of her purifying are completed."
            },
