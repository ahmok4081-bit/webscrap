              "keyParts": [
                "v032_ESV_GEN_044",
                150,
                "p7",
                "verse",
                "v32",
                "plain_text"
              ],
              "value": "32 For your servant became a pledge of safety for the boy to my father, saying, ‘If I do not bring him back to you, then I shall bear the blame before my father all my life.’"
            },
