              "value": "16"
            },
            {
              "rowId": 97,
              "keyParts": [
                97,
                "p5",
                "verse",
                "v16",
                "content"
              ],
              "value": "Those that entered were male and female,"
            },
            {
              "rowId": 98,
              "keyParts": [
                98,
                "p5",
                "verse",
                "v16",
                "note",
                "f"
              ],
              "value": "tn Heb “Those that went in, male and female from all flesh they went in.”"
            },
            {
              "rowId": 99,
              "keyParts": [
                99,
                "p5",
                "verse",
                "v16",
                "content"
              ],
              "value": "just as God commanded him. Then the"
            },
            {
              "rowId": 100,
              "keyParts": [
                100,
                "p5",
                "verse",
                "v16",
                "sc"
              ],
              "value": "Lord"
            },
            {
              "rowId": 101,
              "keyParts": [
                101,
                "p5",
                "verse",
