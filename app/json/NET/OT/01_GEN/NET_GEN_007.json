                "verse",
                "v14",
                "note",
                "f"
              ],
              "value": "tn The verb “entered” is not in the Hebrew text, but is supplied in the translation for stylistic reasons."
            },
            {
              "rowId": 86,
              "keyParts": [
                86,
                "p5",
                "verse",
                "v14",
                "content"
              ],
              "value": "along with every living creature after its kind, every animal after its kind, every creeping thing that creeps on the earth after its kind, and every bird after its kind, everything with wings."
            },
            {
              "rowId": 87,
              "keyParts": [
                87,
                "p5",
                "verse",
                "v14",
                "note",
                "f"
              ],
              "value": "tn Heb “every bird, every wing.”"
            },
            {
              "rowId": 88,
              "keyParts": [
                "v014_NET_GEN_007",
                88,
                "p5",
                "verse",
                "v14",
                "plain_text"
              ],
              "value": "14 They entered, along with every living creature after its kind, every animal after its kind, every creeping thing that creeps on the earth after its kind, and every bird after its kind, everything with wings."
            },
            {
              "rowId": 89,
              "keyParts": [
                89,
                "p5",
                "verse",
                "v15",
                "label"
              ],
              "value": "15"
            },
