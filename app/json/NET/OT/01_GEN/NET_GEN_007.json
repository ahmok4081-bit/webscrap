                "verse",
                "v21",
                "note",
                "f"
              ],
              "value": "tn Heb “flesh.”"
            },
            {
              "rowId": 129,
              "keyParts": [
                129,
                "p6",
                "verse",
                "v21",
                "content"
              ],
              "value": "that moved on the earth died, including the birds, domestic animals, wild animals, all the creatures that swarm over the earth, and all humankind."
            },
            {
              "rowId": 130,
              "keyParts": [
                "v021_NET_GEN_007",
                130,
                "p6",
                "verse",
                "v21",
                "plain_text"
