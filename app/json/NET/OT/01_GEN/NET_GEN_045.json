              "keyParts": [
                71,
                "p2",
                "verse",
                "v13",
                "note",
                "f"
              ],
              "value": "tn Heb “and hurry and bring down my father to here.”"
            },
            {
              "rowId": 72,
              "keyParts": [
                "v013_NET_GEN_045",
                72,
                "p2",
                "verse",
                "v13",
                "plain_text"
              ],
              "value": "13 So tell my father about all my honor in Egypt and about everything you have seen. But bring my father down here quickly!”"
            },
