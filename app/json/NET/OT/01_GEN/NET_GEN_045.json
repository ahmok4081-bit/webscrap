                "p2",
                "verse",
                "v13",
                "note",
                "f"
              ],
              "value": "tn The perfect verbal form with the vav consecutive here expresses instruction."
            },
            {
              "rowId": 70,
              "keyParts": [
                70,
                "p2",
                "verse",
                "v13",
                "content"
              ],
              "value": "my father about all my honor in Egypt and about everything you have seen. But bring my father down here quickly!”"
            },
