            {
              "rowId": 106,
              "keyParts": [
                106,
                "p5",
                "verse",
                "v16",
                "content"
              ],
              "value": "So that same day Esau made his way back"
            },
            {
              "rowId": 107,
              "keyParts": [
                107,
                "p5",
                "verse",
                "v16",
                "note",
                "f"
              ],
              "value": "tn Heb “returned on his way.”"
            },
            {
              "rowId": 108,
              "keyParts": [
                108,
                "p5",
                "verse",
                "v16",
                "content"
              ],
              "value": "to Seir."
            },
            {
              "rowId": 109,
              "keyParts": [
                "v016_NET_GEN_033",
                109,
                "p5",
                "verse",
                "v16",
                "plain_text"
              ],
              "value": "16 So that same day Esau made his way back to Seir."
            },
            {
              "rowId": 110,
              "keyParts": [
                110,
                "p5",
                "verse",
                "v17",
                "label"
