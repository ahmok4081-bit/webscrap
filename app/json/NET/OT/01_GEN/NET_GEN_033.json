                93,
                "p3",
                "verse",
                "v14",
                "content"
              ],
              "value": "Let my lord go on ahead of his servant. I will travel more slowly, at the pace of the herds and the children,"
            },
            {
              "rowId": 94,
              "keyParts": [
                94,
                "p3",
                "verse",
                "v14",
                "note",
                "f"
              ],
              "value": "tn Heb “and I, I will move along according to my leisure at the foot of the property which is before me and at the foot of the children.”"
            },
            {
              "rowId": 95,
              "keyParts": [
                95,
                "p3",
                "verse",
                "v14",
                "content"
              ],
              "value": "until I come to my lord at Seir.”"
            },
            {
              "rowId": 96,
              "keyParts": [
                "v014_NET_GEN_033",
                96,
                "p3",
                "verse",
                "v14",
                "plain_text"
              ],
              "value": "14 Let my lord go on ahead of his servant. I will travel more slowly, at the pace of the herds and the children, until I come to my lord at Seir.”"
            },
            {
              "rowId": 97,
              "keyParts": [
                97,
                "p4",
                "verse",
                "v15",
                "label"
